# Aptale Honcho configuration (canonical path)
#
# Apply env keys to ~/.hermes/.env.
# Workspace selection is configured in ~/.honcho/config.json.

# Required for Honcho-backed user modeling.
HONCHO_API_KEY=your-honcho-api-key

# Hermes docs configure Honcho workspace in ~/.honcho/config.json.
# Use Aptale's canonical workspace:
# {
#   "apiKey": "your-honcho-api-key",
#   "workspace": "aptale-production",
#   "aiPeer": "hermes",
#   "environment": "production",
#   "saveMessages": true,
#   "sessionStrategy": "per-directory",
#   "enabled": true
# }
