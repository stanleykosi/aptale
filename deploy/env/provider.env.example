# Aptale provider configuration (canonical path)
#
# Apply these values to ~/.hermes/.env.
# Secrets must not be committed.

# Required for OpenRouter access.
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Pin Aptale to OpenRouter for inference.
HERMES_INFERENCE_PROVIDER=openrouter

# Fixed initial model recommendation for Aptale.
HERMES_MODEL=anthropic/claude-3.5-sonnet
