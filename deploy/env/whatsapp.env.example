# Aptale WhatsApp Gateway Environment (MVP Beta)
#
# Canonical path: WhatsApp bot mode + explicit allowlist only.
# Do not use open access for Aptale MVP.

WHATSAPP_ENABLED=true
WHATSAPP_MODE=bot

# Comma-separated phone numbers with country code, no "+" prefix.
# Example beta allowlist (replace with real testers):
WHATSAPP_ALLOWED_USERS=15551234567,447123456789,2348012345678

# Optional cross-platform allowlist; not a replacement for WHATSAPP_ALLOWED_USERS.
# Keep empty unless you intentionally need cross-platform overlap.
GATEWAY_ALLOWED_USERS=

# Enforce closed beta access. Keep false or unset.
GATEWAY_ALLOW_ALL_USERS=false
