[Unit]
Description=Aptale Hermes Gateway (Docker Compose)
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/aptale
ExecStart=/usr/bin/docker compose up -d --build aptale-gateway
ExecStop=/usr/bin/docker compose down
ExecReload=/usr/bin/docker compose up -d --build aptale-gateway
TimeoutStartSec=0
TimeoutStopSec=120

[Install]
WantedBy=multi-user.target
