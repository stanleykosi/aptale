{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aptale/schemas/local_charge_quote.schema.json",
  "title": "LocalChargeQuote",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "quote_id",
    "extraction_id",
    "destination_country",
    "currency",
    "total_amount",
    "lines",
    "source_type",
    "sources",
    "captured_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "quote_id": {
      "type": "string",
      "minLength": 1
    },
    "extraction_id": {
      "type": "string",
      "minLength": 1
    },
    "destination_country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "total_amount": {
      "type": "number",
      "minimum": 0
    },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/local_charge_line"
      }
    },
    "source_type": {
      "type": "string",
      "enum": [
        "official_portal",
        "carrier_portal",
        "forwarder_portal",
        "open_web"
      ]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_entry"
      }
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "local_charge_line": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "amount",
        "currency"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "source_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_url",
        "source_title",
        "retrieved_at",
        "method"
      ],
      "properties": {
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "source_title": {
          "type": "string",
          "minLength": 1
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "type": "string",
          "enum": [
            "browserbase",
            "web_search",
            "web_extract"
          ]
        }
      }
    }
  }
}
