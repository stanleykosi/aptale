{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aptale/schemas/customs_quote.schema.json",
  "title": "CustomsQuote",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "quote_id",
    "extraction_id",
    "destination_country",
    "assessment_basis",
    "lines",
    "source_type",
    "sources",
    "captured_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "quote_id": {
      "type": "string",
      "minLength": 1
    },
    "extraction_id": {
      "type": "string",
      "minLength": 1
    },
    "destination_country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "assessment_basis": {
      "type": "string",
      "enum": [
        "cif",
        "fob",
        "invoice_value",
        "unknown"
      ]
    },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/customs_line"
      }
    },
    "source_type": {
      "type": "string",
      "enum": [
        "government_portal",
        "open_web"
      ]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_entry"
      }
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "customs_line": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line_id",
        "hs_code",
        "duty_rate_pct",
        "vat_rate_pct",
        "additional_rate_pct",
        "fixed_fee",
        "fixed_fee_currency",
        "legal_reference"
      ],
      "properties": {
        "line_id": {
          "type": "string",
          "minLength": 1
        },
        "hs_code": {
          "type": "string",
          "pattern": "^[0-9]{4,10}$"
        },
        "duty_rate_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "vat_rate_pct": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        },
        "additional_rate_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "fixed_fee": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "fixed_fee_currency": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Z]{3}$"
        },
        "legal_reference": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "source_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_url",
        "source_title",
        "retrieved_at",
        "method"
      ],
      "properties": {
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "source_title": {
          "type": "string",
          "minLength": 1
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "type": "string",
          "enum": [
            "browserbase",
            "web_search",
            "web_extract"
          ]
        }
      }
    }
  }
}
