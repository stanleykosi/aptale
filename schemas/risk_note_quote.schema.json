{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aptale/schemas/risk_note_quote.schema.json",
  "title": "RiskNoteQuote",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "quote_id",
    "extraction_id",
    "destination_country",
    "risk_level",
    "notes",
    "source_type",
    "sources",
    "captured_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "quote_id": {
      "type": "string",
      "minLength": 1
    },
    "extraction_id": {
      "type": "string",
      "minLength": 1
    },
    "destination_country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/risk_note"
      }
    },
    "source_type": {
      "type": "string",
      "enum": [
        "government_portal",
        "trade_advisory",
        "open_web"
      ]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_entry"
      }
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "risk_note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "title",
        "description",
        "impact_level",
        "recommendation"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "impact_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_url",
        "source_title",
        "retrieved_at",
        "method"
      ],
      "properties": {
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "source_title": {
          "type": "string",
          "minLength": 1
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "type": "string",
          "enum": [
            "browserbase",
            "web_search",
            "web_extract"
          ]
        }
      }
    }
  }
}
