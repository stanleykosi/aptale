{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aptale/schemas/freight_quote.schema.json",
  "title": "FreightQuote",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "quote_id",
    "extraction_id",
    "provider_name",
    "origin_country",
    "destination_country",
    "origin_port",
    "destination_port",
    "mode",
    "service_level",
    "transit_time_days",
    "currency",
    "quote_amount",
    "charge_breakdown",
    "valid_until",
    "source_type",
    "sources",
    "captured_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "quote_id": {
      "type": "string",
      "minLength": 1
    },
    "extraction_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_name": {
      "type": "string",
      "minLength": 1
    },
    "origin_country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "destination_country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "origin_port": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "destination_port": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "air",
        "sea",
        "road",
        "rail",
        "multimodal"
      ]
    },
    "service_level": {
      "type": "string",
      "enum": [
        "express",
        "standard",
        "economy",
        "unknown"
      ]
    },
    "transit_time_days": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "quote_amount": {
      "type": "number",
      "minimum": 0
    },
    "charge_breakdown": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/charge_line"
      }
    },
    "valid_until": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "official_portal",
        "carrier_portal",
        "forwarder_portal",
        "open_web"
      ]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_entry"
      }
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "charge_line": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "amount",
        "currency"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "source_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_url",
        "source_title",
        "retrieved_at",
        "method"
      ],
      "properties": {
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "source_title": {
          "type": "string",
          "minLength": 1
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "type": "string",
          "enum": [
            "browserbase",
            "web_search",
            "web_extract"
          ]
        }
      }
    }
  }
}
