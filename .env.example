# Aptale environment contract
# Copy the values you actually use into `~/.hermes/.env` or your secret manager.
# Do not commit real secrets.

# Required secrets
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
BROWSERBASE_API_KEY=your-browserbase-api-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id
HONCHO_API_KEY=your-honcho-api-key
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_private_skills_pat

# Required runtime configuration
WHATSAPP_ENABLED=true
WHATSAPP_MODE=bot
WHATSAPP_ALLOWED_USERS=15551234567
BROWSERBASE_PROXIES=true

# Optional production monitoring
APTALE_ADMIN_ALERT_WEBHOOK_URL=

# Optional Aptale quote-loop bridge (Hermes gateway -> Aptale runtime)
# Enable only when Hermes runtime can import /home/.../aptale/src
# APTALE_QUOTE_LOOP_ENABLED=true
# APTALE_HERMES_BRIDGE_PATCH=true
# APTALE_REPO_ROOT=/absolute/path/to/aptale
# APTALE_DEFAULT_COUNTRY=NG
# APTALE_DEFAULT_CURRENCY=NGN
# APTALE_DEFAULT_MARGIN_PCT=18
# APTALE_DEFAULT_TIMEZONE=Africa/Lagos
# APTALE_EXPORT_FORMAT=pdf
# APTALE_EXPORT_OUTPUT_DIR=/absolute/path/to/.hermes/runtime/exports

# Optional local speech-to-text (recommended for WhatsApp voice notes; no OpenAI key required)
# APTALE_LOCAL_STT_ENABLED=true
# APTALE_STT_PROVIDER=local            # local | openai | auto
# APTALE_STT_MODEL=small               # tiny | base | small | medium | large-v3
# APTALE_STT_DEVICE=auto               # auto | cpu | cuda
# APTALE_STT_COMPUTE_TYPE=int8         # int8 for CPU, float16/int8_float16 for CUDA
# APTALE_STT_BEAM_SIZE=1
# APTALE_AUDIO_IN_AUDIO_OUT=true       # Voice note in -> voice reply out (WhatsApp)
# APTALE_AUDIO_REPLY_MODE=audio_only   # audio_only | audio_plus_text
# ORT_LOG_SEVERITY_LEVEL=3             # reduce benign onnxruntime warnings in logs
# HERMES_TOOL_PROGRESS_MODE=off        # disable terminal-style tool logs in chat

# Optional runtime overrides
# HERMES_HOME=/absolute/path/to/.hermes
# MESSAGING_CWD=/absolute/path/to/aptale
# GATEWAY_ALLOWED_USERS=
# GATEWAY_ALLOW_ALL_USERS=false
# BROWSERBASE_ADVANCED_STEALTH=false
# BROWSERBASE_KEEP_ALIVE=true
# BROWSERBASE_SESSION_TIMEOUT=600000
# BROWSER_INACTIVITY_TIMEOUT=300
