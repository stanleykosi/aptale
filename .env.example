# Aptale environment contract
# Copy the values you actually use into `~/.hermes/.env` or your secret manager.
# Do not commit real secrets.

# Required secrets
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
BROWSERBASE_API_KEY=your-browserbase-api-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id
HONCHO_API_KEY=your-honcho-api-key
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_private_skills_pat

# Required runtime configuration
WHATSAPP_ENABLED=true
WHATSAPP_MODE=bot
WHATSAPP_ALLOWED_USERS=15551234567
BROWSERBASE_PROXIES=true

# Optional production monitoring
APTALE_ADMIN_ALERT_WEBHOOK_URL=

# Optional runtime overrides
# HERMES_HOME=/absolute/path/to/.hermes
# MESSAGING_CWD=/absolute/path/to/aptale
# GATEWAY_ALLOWED_USERS=
# GATEWAY_ALLOW_ALL_USERS=false
# BROWSERBASE_ADVANCED_STEALTH=false
# BROWSERBASE_KEEP_ALIVE=true
# BROWSERBASE_SESSION_TIMEOUT=600000
# BROWSER_INACTIVITY_TIMEOUT=300
